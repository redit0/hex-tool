configHelp = function()
	text = g.const.ni + g.l3("Usage:","u") + g.const.ni
	text = text + g.g2(self.name) + g.l2(" Displays a summary of all stored configuration.") + g.const.ni
	text = text + g.g2(self.name) + g.b3(" proxy") + g.l2(" Lists all saved proxies.") + g.const.ni
	text = text + g.g2(self.name) + g.b3(" proxy add [ip] [user] [pass]") + g.l2(" {port}") + g.l2(" Adds a proxy. Port defaults to 22.") + g.const.ni
	text = text + g.g2(self.name) + g.b3(" proxy remove [#]") + g.l2(" Removes a proxy by its list number.") + g.const.ni
	text = text + g.g2(self.name) + g.b3(" rshell") + g.l2(" Shows the saved rshell server.") + g.const.ni
	text = text + g.g2(self.name) + g.b3(" rshell set [ip] [user] [pass]") + g.l2(" {port}") + g.l2(" Sets the rshell server. Port defaults to 1222.") + g.const.ni
	text = text + g.g2(self.name) + g.b3(" rshell remove") + g.l2(" Clears the saved rshell server.") + g.const.ni
	text = text + g.g2(self.name) + g.b3(" mail") + g.l2(" Shows the saved mail credentials.") + g.const.ni
	text = text + g.g2(self.name) + g.b3(" mail set [address] [password]") + g.l2(" Sets mail credentials.") + g.const.ni
	text = text + g.g2(self.name) + g.b3(" mail remove") + g.l2(" Clears the saved mail credentials.") + g.const.ni
	text = text + g.g2(self.name) + g.b3(" ssh") + g.l2(" Lists all saved SSH connections.") + g.const.ni
	text = text + g.g2(self.name) + g.b3(" ssh add [name] [ip] [pass]") + g.l2(" {user} {port}") + g.l2(" Saves an SSH connection. User defaults to root, port to 22.") + g.const.ni
	text = text + g.g2(self.name) + g.b3(" ssh remove [name]") + g.l2(" Removes a saved SSH connection by name.") + g.const.ni
	text = text + g.g2(self.name) + g.b3(" [-h/help]") + g.l2(" Displays this help text.") + g.const.nl

	print(text)
end function

doConfig = function(args = null)
	ni = g.const.ni
	indent = g.const.indent

	// Summary view
	if args == null or args == [] then
		config = g.func.loadConfig

		proxyCount = config.proxies.len

		rshellStr = g.d1("not set")
		if config.rshell != null then
			r = config.rshell
			rshellStr = g.l2(r.user + "@" + r.ip + ":" + r.port)
		end if

		mailStr = g.d1("not set")
		if config.mail != null then
			mailStr = g.l2(config.mail.address)
		end if

		sshCount = config.ssh.len

		text = ni + indent + g.l3("Configuration Summary", "u") + ni
		text = text + indent + g.s3("Proxies: ") + g.l2(str(proxyCount) + " saved") + ni
		text = text + indent + g.s3("SSH:     ") + g.l2(str(sshCount) + " saved") + ni
		text = text + indent + g.s3("Rshell:  ") + rshellStr + ni
		text = text + indent + g.s3("Mail:    ") + mailStr + g.const.nl
		print(text)
		return 1
	end if

	if args[0] == "-h" or args[0] == "help" then
		self.help
		return 1
	end if

	// ── proxy ──────────────────────────────────────────────────
	if args[0] == "proxy" then
		if args.len == 1 then
			config = g.func.loadConfig
			if config.proxies.len == 0 then
				print indent + g.d1("No proxies saved.")
				return 1
			end if

			text = ni
			num = 1
			for proxy in config.proxies
				masked = g.func.maskPassword(proxy.pass)
				port = 22
				if proxy.hasIndex("port") then port = proxy.port
				text = text + indent + g.o1(str(num) + ".") + "<pos=120>" + g.l2(proxy.user + "@" + proxy.ip + ":" + port) + g.s3("<pos=450>pass: ") + masked + ni
				num = num + 1
			end for
			print(text)
			return 1

		else if args[1] == "add" then
			if args.len < 5 then
				print g.error("Usage: config proxy add [ip] [user] [pass] {port}")
				return 0
			end if

			ip = args[2]
			user = args[3]
			pass = args[4]
			port = 22
			if args.len > 5 and typeof(args[5].to_int) == "number" then
				port = args[5].to_int
			end if

			if not is_valid_ip(ip) then
				print g.error("Invalid IP address: " + ip)
				return 0
			end if
			if port < 0 or port > 65535 then
				print g.error("Invalid port: " + str(port))
				return 0
			end if

			config = g.func.loadConfig
			config.proxies.push({"ip": ip, "port": port, "user": user, "pass": pass})

			if g.func.saveConfig(config) then
				if not g.hasIndex("proxies") then g.proxies = []
				g.proxies.push([ip, port, user, pass])
				print indent + g.g1("Proxy saved: " + user + "@" + ip + ":" + port)
				if not g.func.add_proxy(ip, port, user, pass, 1) then
					print indent + g.o1("Credentials saved but could not connect. Will retry on next proxy start.")
				end if
				return 1
			end if
			return 0

		else if args[1] == "remove" then
			if args.len < 3 or typeof(args[2].to_int) != "number" then
				print g.error("Usage: config proxy remove [#]")
				return 0
			end if

			config = g.func.loadConfig
			idx = args[2].to_int - 1
			if idx < 0 or not config.proxies.hasIndex(idx) then
				print g.error("Invalid proxy number.")
				return 0
			end if

			removed = config.proxies[idx]
			config.proxies.remove(idx)

			if g.func.saveConfig(config) then
				g.proxies = []
				for p in config.proxies
					prt = 22
					if p.hasIndex("port") then prt = p.port
					g.proxies.push([p.ip, prt, p.user, p.pass])
				end for
				print indent + g.g1("Removed proxy: " + removed.user + "@" + removed.ip)
				return 1
			end if
			return 0
		else
			self.help
			return 0
		end if

	// ── rshell ─────────────────────────────────────────────────
	else if args[0] == "rshell" then
		if args.len == 1 then
			config = g.func.loadConfig
			if config.rshell == null then
				print indent + g.d1("No rshell server saved.")
				return 1
			end if

			r = config.rshell
			masked = g.func.maskPassword(r.pass)
			text = ni
			text = text + indent + g.s3("IP:   ") + g.l2(r.ip) + ni
			text = text + indent + g.s3("Port: ") + g.l2(str(r.port)) + ni
			text = text + indent + g.s3("User: ") + g.l2(r.user) + ni
			text = text + indent + g.s3("Pass: ") + masked + g.const.nl
			print(text)
			return 1

		else if args[1] == "set" then
			if args.len < 5 then
				print g.error("Usage: config rshell set [ip] [user] [pass] {port}")
				return 0
			end if

			ip = args[2]
			user = args[3]
			pass = args[4]
			port = 1222
			if args.len > 5 and typeof(args[5].to_int) == "number" then
				port = args[5].to_int
			end if

			if not is_valid_ip(ip) then
				print g.error("Invalid IP address: " + ip)
				return 0
			end if
			if port < 0 or port > 65535 then
				print g.error("Invalid port: " + str(port))
				return 0
			end if

			config = g.func.loadConfig
			config.rshell = {"ip": ip, "port": port, "user": user, "pass": pass}

			if g.func.saveConfig(config) then
				print indent + g.g1("Rshell server saved: " + user + "@" + ip + ":" + port)
				if not g.func.init_rshell(null, port) or not g.func.start_rshell(g.rshell.key) then
					print indent + g.o1("Credentials saved but could not connect. Will retry on next startup.")
				end if
				return 1
			end if
			return 0

		else if args[1] == "remove" then
			config = g.func.loadConfig
			config.rshell = null

			if g.func.saveConfig(config) then
				print indent + g.g1("Rshell server cleared.")
				return 1
			end if
			return 0
		else
			self.help
			return 0
		end if

	// ── ssh ────────────────────────────────────────────────────
	else if args[0] == "ssh" then
		if args.len == 1 then
			config = g.func.loadConfig
			if config.ssh.len == 0 then
				print indent + g.d1("No SSH connections saved.")
				return 1
			end if

			text = ni
			for name in config.ssh.indexes
				entry = config.ssh[name]
				masked = g.func.maskPassword(entry.pass)
				port = 22
				if entry.hasIndex("port") then port = entry.port
				text = text + indent + g.o1(name) + "<pos=200>" + g.l2(entry.user + "@" + entry.ip + ":" + port) + g.s3("<pos=550>pass: ") + masked + ni
			end for
			print(text)
			return 1

		else if args[1] == "add" then
			if args.len < 5 then
				print g.error("Usage: config ssh add [name] [ip] [pass] {user} {port}")
				return 0
			end if

			name = args[2]
			ip = args[3]
			pass = args[4]
			user = "root"
			port = 22

			if args.len > 5 then user = args[5]
			if args.len > 6 and typeof(args[6].to_int) == "number" then
				port = args[6].to_int
			end if

			if not is_valid_ip(ip) then
				print g.error("Invalid IP address: " + ip)
				return 0
			end if
			if port < 0 or port > 65535 then
				print g.error("Invalid port: " + str(port))
				return 0
			end if

			config = g.func.loadConfig
			if config.ssh.hasIndex(name) then
				print g.error("An SSH connection with that name already exists: " + name)
				return 0
			end if

			config.ssh[name] = {"ip": ip, "port": port, "user": user, "pass": pass}

			if g.func.saveConfig(config) then
				print indent + g.g1("SSH connection saved: " + name + " (" + user + "@" + ip + ":" + port + ")")
				return 1
			end if
			return 0

		else if args[1] == "remove" then
			if args.len < 3 then
				print g.error("Usage: config ssh remove [name]")
				return 0
			end if

			name = args[2]
			config = g.func.loadConfig

			if not config.ssh.hasIndex(name) then
				print g.error("No SSH connection saved with name: " + name)
				return 0
			end if

			config.ssh.remove(name)

			if g.func.saveConfig(config) then
				print indent + g.g1("Removed SSH connection: " + name)
				return 1
			end if
			return 0
		else
			self.help
			return 0
		end if

	// ── mail ───────────────────────────────────────────────────
	else if args[0] == "mail" then
		if args.len == 1 then
			config = g.func.loadConfig
			if config.mail == null then
				print indent + g.d1("No mail credentials saved.")
				return 1
			end if

			m = config.mail
			masked = g.func.maskPassword(m.pass)
			text = ni
			text = text + indent + g.s3("Address:  ") + g.l2(m.address) + ni
			text = text + indent + g.s3("Password: ") + masked + g.const.nl
			print(text)
			return 1

		else if args[1] == "set" then
			if args.len < 4 then
				print g.error("Usage: config mail set [address] [password]")
				return 0
			end if

			address = args[2]
			pass = args[3]

			config = g.func.loadConfig
			config.mail = {"address": address, "pass": pass}

			if g.func.saveConfig(config) then
				mail = mail_login(address, pass)
				if mail and typeof(mail) != "string" then
					g.mail = mail
					print indent + g.g1("Mail credentials set and connected: " + address)
				else
					msg = "Mail credentials saved."
					if typeof(mail) == "string" then msg = msg + " Login failed: " + mail
					print indent + g.o1(msg)
				end if
				return 1
			end if
			return 0

		else if args[1] == "remove" then
			config = g.func.loadConfig
			config.mail = null

			if g.func.saveConfig(config) then
				g.mail = null
				print indent + g.g1("Mail credentials cleared.")
				return 1
			end if
			return 0
		else
			self.help
			return 0
		end if
	else
		self.help
		return 0
	end if
end function

g.util.config = {
	"name": "config",
	"shortDescription": "Manages saved configuration.",
	"exec": @doConfig,
	"help": @configHelp,
	"data": {}
}
