router = get_router

ports = router.used_ports

print "Used Ports:"

for port in ports
    print "Number: " + port.port_number
    print "LAN IP: " + port.get_lan_ip
    print "IsClosed: " + port.is_closed
end for

ports = router.device_ports(router.local_ip)

print "Device Ports:"

for port in ports
    print "Number: " + port.port_number
    print "LAN IP: " + port.get_lan_ip
    print "IsClosed: " + port.is_closed
end for
